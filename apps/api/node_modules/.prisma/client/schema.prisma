generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  FPA
  CONTRIBUTEUR
  LECTEUR
}

enum PlanTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum FiscalStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum BudgetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  LOCKED
  REJECTED
}

enum LineType {
  REVENUE
  EXPENSE
  CAPEX
}

enum ScenarioType {
  OPTIMISTE
  BASE
  PESSIMISTE
  CUSTOM
}

enum ScenarioStatus {
  DRAFT
  CALCULATED
  SAVED
}

enum AccountType {
  BANK
  WAVE
  ORANGE_MONEY
  MTN_MOMO
}

enum ImportSource {
  EXCEL
  SAGE
  MANUAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum AlertSeverity {
  INFO
  WARN
  CRITICAL
}

enum AuditAction {
  LOGIN
  LOGOUT
  BUDGET_CREATE
  BUDGET_SUBMIT
  BUDGET_APPROVE
  BUDGET_REJECT
  BUDGET_LOCK
  IMPORT_START
  IMPORT_DONE
  PERIOD_CLOSE
  SCENARIO_SAVE
  EXPORT
  AUDIT_ACCESS_CREATE
  AUDIT_ACCESS_REVOKE
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  USER_ACTIVATE
  PASSWORD_CHANGE
  BALANCE_UPDATE
  TRANSACTION_VALIDATE
  TRANSACTION_DELETE
}

model Organization {
  id                  String              @id @default(uuid())
  name                String
  country             String
  currency            String              @default("XOF")
  plan                PlanTier            @default(STARTER)
  is_active           Boolean             @default(true)
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  users               User[]
  audit_logs          AuditLog[]
  audit_access        AuditAccess[]
  fiscal_years        FiscalYear[]
  periods             Period[]
  budgets             Budget[]
  budget_lines        BudgetLine[]
  transactions        Transaction[]
  import_jobs         ImportJob[]
  bank_accounts       BankAccount[]
  cash_flow_plans     CashFlowPlan[]
  scenarios           Scenario[]
  financial_snapshots FinancialSnapshot[]
  kpis                Kpi[]
  kpi_values          KpiValue[]
  alerts              Alert[]

  @@map("organizations")
}

model User {
  id                     String                @id @default(uuid())
  org_id                 String
  email                  String                @unique
  password_hash          String
  first_name             String
  last_name              String
  role                   UserRole
  is_active              Boolean               @default(true)
  last_login_at          DateTime?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  organization           Organization          @relation(fields: [org_id], references: [id])
  department_scopes      UserDepartmentScope[]
  audit_logs             AuditLog[]
  audit_access_created   AuditAccess[]         @relation("AuditAccessCreatedBy")
  closed_periods         Period[]              @relation("PeriodClosedBy")
  budget_submitted       Budget[]              @relation("BudgetSubmittedBy")
  budget_approved        Budget[]              @relation("BudgetApprovedBy")
  budget_locked          Budget[]              @relation("BudgetLockedBy")
  budget_lines_created   BudgetLine[]
  transactions_validated Transaction[]         @relation("TransactionValidatedBy")
  import_jobs_created    ImportJob[]
  scenarios_created      Scenario[]

  @@unique([org_id, email])
  @@index([org_id])
  @@map("users")
}

model UserDepartmentScope {
  id         String  @id @default(uuid())
  user_id    String
  department String
  can_read   Boolean @default(true)
  can_write  Boolean @default(false)
  user       User    @relation(fields: [user_id], references: [id])

  @@unique([user_id, department])
  @@map("user_department_scope")
}

model AuditLog {
  id           String       @id @default(uuid())
  org_id       String
  user_id      String?
  action       AuditAction
  entity_type  String
  entity_id    String?
  ip_address   String?
  metadata     Json?
  created_at   DateTime     @default(now())
  organization Organization @relation(fields: [org_id], references: [id])
  user         User?        @relation(fields: [user_id], references: [id])

  @@index([org_id])
  @@map("audit_logs")
}

model AuditAccess {
  id               String       @id @default(uuid())
  org_id           String
  created_by       String
  email_auditeur   String
  token_hash       String       @unique
  expires_at       DateTime
  permissions      Json
  last_accessed_at DateTime?
  is_revoked       Boolean      @default(false)
  created_at       DateTime     @default(now())
  organization     Organization @relation(fields: [org_id], references: [id])
  creator          User         @relation("AuditAccessCreatedBy", fields: [created_by], references: [id])

  @@index([org_id])
  @@index([token_hash])
  @@map("audit_access")
}

model FiscalYear {
  id           String       @id @default(uuid())
  org_id       String
  label        String
  start_date   DateTime
  end_date     DateTime
  status       FiscalStatus @default(ACTIVE)
  created_at   DateTime     @default(now())
  organization Organization @relation(fields: [org_id], references: [id])
  periods      Period[]
  budgets      Budget[]

  @@unique([org_id, label])
  @@index([org_id])
  @@map("fiscal_years")
}

model Period {
  id                  String              @id @default(uuid())
  fiscal_year_id      String
  org_id              String
  label               String
  period_number       Int
  start_date          DateTime
  end_date            DateTime
  status              PeriodStatus        @default(OPEN)
  closed_at           DateTime?
  closed_by           String?
  fiscal_year         FiscalYear          @relation(fields: [fiscal_year_id], references: [id])
  organization        Organization        @relation(fields: [org_id], references: [id])
  closed_by_user      User?               @relation("PeriodClosedBy", fields: [closed_by], references: [id])
  budget_lines        BudgetLine[]
  transactions        Transaction[]
  import_jobs         ImportJob[]
  cash_flow_plans     CashFlowPlan[]
  financial_snapshots FinancialSnapshot[]
  kpi_values          KpiValue[]
  alerts              Alert[]

  @@unique([fiscal_year_id, period_number])
  @@index([org_id])
  @@map("periods")
}

model Budget {
  id                String       @id @default(uuid())
  org_id            String
  fiscal_year_id    String
  name              String
  version           Int          @default(1)
  status            BudgetStatus @default(DRAFT)
  submitted_at      DateTime?
  submitted_by      String?
  approved_at       DateTime?
  approved_by       String?
  locked_at         DateTime?
  locked_by         String?
  rejection_comment String?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  organization      Organization @relation(fields: [org_id], references: [id])
  fiscal_year       FiscalYear   @relation(fields: [fiscal_year_id], references: [id])
  submitted_by_user User?        @relation("BudgetSubmittedBy", fields: [submitted_by], references: [id])
  approved_by_user  User?        @relation("BudgetApprovedBy", fields: [approved_by], references: [id])
  locked_by_user    User?        @relation("BudgetLockedBy", fields: [locked_by], references: [id])
  budget_lines      BudgetLine[]
  scenarios         Scenario[]

  @@index([org_id])
  @@index([org_id, status])
  @@map("budgets")
}

model BudgetLine {
  id            String       @id @default(uuid())
  budget_id     String
  org_id        String
  period_id     String
  account_code  String
  account_label String
  department    String
  line_type     LineType
  amount_budget Decimal      @db.Decimal(18, 2)
  amount_actual Decimal      @default(0) @db.Decimal(18, 2)
  created_by    String
  updated_at    DateTime     @updatedAt
  budget        Budget       @relation(fields: [budget_id], references: [id])
  organization  Organization @relation(fields: [org_id], references: [id])
  period        Period       @relation(fields: [period_id], references: [id])
  creator       User         @relation(fields: [created_by], references: [id])

  @@index([org_id])
  @@index([org_id, period_id])
  @@map("budget_lines")
}

model Transaction {
  id            String       @id @default(uuid())
  org_id        String
  period_id     String
  account_code  String
  account_label String
  department    String
  amount        Decimal      @db.Decimal(18, 2)
  is_validated  Boolean      @default(false)
  validated_by  String?
  import_job_id String?
  created_at    DateTime     @default(now())
  organization  Organization @relation(fields: [org_id], references: [id])
  period        Period       @relation(fields: [period_id], references: [id])
  validator     User?        @relation("TransactionValidatedBy", fields: [validated_by], references: [id])
  import_job    ImportJob?   @relation(fields: [import_job_id], references: [id])

  @@index([org_id])
  @@index([org_id, period_id])
  @@map("transactions")
}

model ImportJob {
  id            String        @id @default(uuid())
  org_id        String
  period_id     String
  created_by    String
  source        ImportSource
  status        ImportStatus  @default(PENDING)
  file_name     String
  file_size_kb  Int
  rows_inserted Int?
  rows_skipped  Int?
  error_report  Json?
  started_at    DateTime?
  completed_at  DateTime?
  created_at    DateTime      @default(now())
  organization  Organization  @relation(fields: [org_id], references: [id])
  period        Period        @relation(fields: [period_id], references: [id])
  creator       User          @relation(fields: [created_by], references: [id])
  transactions  Transaction[]

  @@index([org_id])
  @@map("import_jobs")
}

model BankAccount {
  id           String       @id @default(uuid())
  org_id       String
  name         String
  account_type AccountType
  balance      Decimal      @default(0) @db.Decimal(18, 2)
  currency     String       @default("XOF")
  is_active    Boolean      @default(true)
  created_at   DateTime     @default(now())
  organization Organization @relation(fields: [org_id], references: [id])

  @@index([org_id])
  @@map("bank_accounts")
}

model CashFlowPlan {
  id           String       @id @default(uuid())
  org_id       String
  period_id    String
  week_number  Int
  label        String
  inflow       Decimal      @default(0) @db.Decimal(18, 2)
  outflow      Decimal      @default(0) @db.Decimal(18, 2)
  balance      Decimal      @default(0) @db.Decimal(18, 2)
  runway_weeks Int?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  organization Organization @relation(fields: [org_id], references: [id])
  period       Period       @relation(fields: [period_id], references: [id])

  @@index([org_id])
  @@map("cash_flow_plans")
}

model Scenario {
  id            String               @id @default(uuid())
  org_id        String
  budget_id     String
  name          String
  type          ScenarioType
  status        ScenarioStatus       @default(DRAFT)
  calculated_at DateTime?
  saved_at      DateTime?
  created_by    String
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt
  organization  Organization         @relation(fields: [org_id], references: [id])
  budget        Budget               @relation(fields: [budget_id], references: [id])
  creator       User                 @relation(fields: [created_by], references: [id])
  hypotheses    ScenarioHypothesis[]
  snapshots     FinancialSnapshot[]
  kpi_values    KpiValue[]

  @@index([org_id])
  @@index([org_id, status])
  @@map("scenarios")
}

model ScenarioHypothesis {
  id          String   @id @default(uuid())
  scenario_id String
  label       String
  parameter   String
  value       Decimal  @db.Decimal(18, 2)
  unit        String
  created_at  DateTime @default(now())
  scenario    Scenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)

  @@map("scenario_hypotheses")
}

model FinancialSnapshot {
  id             String       @id @default(uuid())
  org_id         String
  period_id      String
  scenario_id    String?
  is_revenue     Decimal      @db.Decimal(18, 2)
  is_expenses    Decimal      @db.Decimal(18, 2)
  is_ebitda      Decimal      @db.Decimal(18, 2)
  is_net         Decimal      @db.Decimal(18, 2)
  bs_assets      Decimal      @db.Decimal(18, 2)
  bs_liabilities Decimal      @db.Decimal(18, 2)
  bs_equity      Decimal      @db.Decimal(18, 2)
  cf_operating   Decimal      @db.Decimal(18, 2)
  cf_investing   Decimal      @db.Decimal(18, 2)
  cf_financing   Decimal      @db.Decimal(18, 2)
  calculated_at  DateTime     @default(now())
  organization   Organization @relation(fields: [org_id], references: [id])
  period         Period       @relation(fields: [period_id], references: [id])
  scenario       Scenario?    @relation(fields: [scenario_id], references: [id])

  @@unique([org_id, period_id, scenario_id])
  @@index([org_id])
  @@map("financial_snapshots")
}

model Kpi {
  id                 String       @id @default(uuid())
  org_id             String
  code               String
  label              String
  formula            String
  unit               String
  threshold_warn     Decimal?     @db.Decimal(18, 2)
  threshold_critical Decimal?     @db.Decimal(18, 2)
  is_active          Boolean      @default(true)
  created_at         DateTime     @default(now())
  organization       Organization @relation(fields: [org_id], references: [id])
  values             KpiValue[]
  alerts             Alert[]

  @@unique([org_id, code])
  @@index([org_id])
  @@map("kpis")
}

model KpiValue {
  id            String        @id @default(uuid())
  kpi_id        String
  org_id        String
  period_id     String
  scenario_id   String?
  value         Decimal       @db.Decimal(18, 2)
  severity      AlertSeverity @default(INFO)
  calculated_at DateTime      @default(now())
  kpi           Kpi           @relation(fields: [kpi_id], references: [id])
  organization  Organization  @relation(fields: [org_id], references: [id])
  period        Period        @relation(fields: [period_id], references: [id])
  scenario      Scenario?     @relation(fields: [scenario_id], references: [id])

  @@index([org_id])
  @@index([org_id, period_id])
  @@map("kpi_values")
}

model Alert {
  id           String        @id @default(uuid())
  org_id       String
  kpi_id       String
  period_id    String
  severity     AlertSeverity
  message      String
  is_read      Boolean       @default(false)
  created_at   DateTime      @default(now())
  organization Organization  @relation(fields: [org_id], references: [id])
  kpi          Kpi           @relation(fields: [kpi_id], references: [id])
  period       Period        @relation(fields: [period_id], references: [id])

  @@index([org_id])
  @@map("alerts")
}
