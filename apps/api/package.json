{
  "name": "jupiter-plan-api",
  "private": true,
  "scripts": {
    "prebuild": "rimraf dist",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "test:integration": "ts-node test/setup-integration.ts && jest --passWithNoTests",
    "test:integration:watch": "ts-node test/setup-integration.ts && jest --watch --passWithNoTests",
    "test:e2e": "jest --config test/e2e/jest.e2e.config.ts",
    "test:e2e:watch": "jest --config test/e2e/jest.e2e.config.ts --watch",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run seed"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.22.0",
    "@types/cookie-parser": "^1.4.10",
    "argon2": "^0.41.1",
    "bullmq": "^5.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@types/xlsx": "^0.0.36",
    "exceljs": "^4.4.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
