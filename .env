POSTGRES_DB=jupiter_plan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_PASSWORD=redis_password_local

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jupiter_plan
REDIS_URL=redis://:redis_password_local@redis:6380

JWT_SECRET=dev-jwt-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=30d

WEB_URL=http://localhost:5173
CALC_ENGINE_URL=http://calc:8000
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Optional object storage settings
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
